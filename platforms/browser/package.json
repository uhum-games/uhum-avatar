{
  "name": "@uhum/avatar",
  "version": "0.1.0",
  "description": "Uhum Avatar client for browsers - connects to UHUM agents and renders Uhum View",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "build:wasm": "cd ../../crates/ua-wasm && wasm-pack build --target web --out-dir ../../platforms/browser/wasm",
    "dev": "tsc --watch",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist wasm"
  },
  "dependencies": {
    "react": "^18.2.0"
  },
  "peerDependencies": {
    "react": ">=17.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0"
  },
  "keywords": [
    "uhum",
    "avatar",
    "ai",
    "agent",
    "wasm"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/uhum/uhum-avatar"
  }
}
