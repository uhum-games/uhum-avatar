{
  "name": "@uhum/avatar-browser",
  "version": "0.1.0",
  "private": true,
  "description": "Uhum Avatar browser platform - library and deployable app",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @uhum/avatar-app dev",
    "dev:mock": "pnpm --filter @uhum/avatar-app dev:mock",
    "build": "pnpm --filter @uhum/avatar-lib build && pnpm --filter @uhum/avatar-app build",
    "build:wasm": "cd ../../crates/ua-wasm && wasm-pack build --target web --out-dir ../../platforms/browser/lib/wasm",
    "preview": "pnpm --filter @uhum/avatar-app preview",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm --filter @uhum/avatar-lib test",
    "test:watch": "pnpm --filter @uhum/avatar-lib test:watch",
    "clean": "rm -rf lib/dist app/dist lib/wasm"
  },
  "devDependencies": {
    "typescript": "^5.3.0"
  }
}
